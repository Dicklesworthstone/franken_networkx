+/// br-r37-c1-mgdt4 (cc): reusable scratch for the single-target MultiGraph Dijkstra,
+/// mirroring the landed `MultiDiDijkstraTargetScratch`. Retains capacity across calls
+/// so the four O(n) buffers + heap + chain are not re-malloced per query; the per-call
+/// `reset(n)` restores the exact starting state, so output is byte-identical.
+#[derive(Default)]
+struct MgTargetScratch {
+    distances: Vec<f64>,
+    predecessors: Vec<usize>,
+    all_int_paths: Vec<bool>,
+    finalized: Vec<bool>,
+    pq: BinaryHeap<PyDijkstraState>,
+    chain: Vec<usize>,
+}
+
+impl MgTargetScratch {
+    fn reset(&mut self, n: usize) {
+        self.distances.clear();
+        self.distances.resize(n, f64::INFINITY);
+        self.predecessors.clear();
+        self.predecessors.resize(n, usize::MAX);
+        self.all_int_paths.clear();
+        self.all_int_paths.resize(n, false);
+        self.finalized.clear();
+        self.finalized.resize(n, false);
+        self.pq.clear();
+        self.chain.clear();
+    }
+}
+
+thread_local! {
+    static MG_TARGET_SCRATCH: RefCell<MgTargetScratch> = RefCell::new(MgTargetScratch::default());
+}
