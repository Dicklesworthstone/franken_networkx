+    /// br-r37-c1-kneserbatch: paired-interleaved median A/B for kneser_graph — inline per-edge
+    /// baseline vs the shipped batch, one binary / one worker with a NULL control. KG(22,2) has
+    /// 231 nodes and ~21945 edges (dense), so the per-edge policy record on each disjoint-subset
+    /// edge is the cost the batch removes (the O(subsets^2) disjoint-check loop is common to both
+    /// arms). Parity asserted first. `#[ignore]`; run with
+    /// `cargo test --release -p fnx-algorithms --lib kneser_graph_batch_ab -- --ignored --nocapture`.
+    #[test]
+    #[ignore = "measurement; run with --release --ignored --nocapture"]
+    fn kneser_graph_batch_ab() {
+        use crate::combinations;
+        use std::hint::black_box;
+        use std::time::Instant;
+
+        let build = |n: usize, k: usize, batch: bool| -> Graph {
+            let mut g = Graph::strict();
+            let subsets = combinations(n, k);
+            let names: Vec<String> = subsets
+                .iter()
+                .map(|s| {
+                    s.iter()
+                        .map(|i| i.to_string())
+                        .collect::<Vec<_>>()
+                        .join(",")
+                })
+                .collect();
+            for name in &names {
+                g.add_node(name.as_str());
+            }
+            if batch {
+                let mut edges: Vec<(&str, &str)> = Vec::new();
+                for i in 0..subsets.len() {
+                    for j in (i + 1)..subsets.len() {
+                        if subsets[i].iter().all(|x| !subsets[j].contains(x)) {
+                            edges.push((names[i].as_str(), names[j].as_str()));
+                        }
+                    }
+                }
+                let _ = g.extend_edges_unrecorded(edges);
+            } else {
+                for i in 0..subsets.len() {
+                    for j in (i + 1)..subsets.len() {
+                        if subsets[i].iter().all(|x| !subsets[j].contains(x)) {
+                            let _ = g.add_edge(names[i].as_str(), names[j].as_str());
+                        }
+                    }
+                }
+            }
+            g
+        };
+
+        let old = build(22, 2, false);
+        let new = build(22, 2, true);
+        assert_eq!(
+            old.edges_ordered_borrowed(),
+            new.edges_ordered_borrowed(),
+            "batch kneser_graph must equal the per-edge baseline"
+        );
+        assert_eq!(old.nodes_ordered(), new.nodes_ordered());
+
+        let time = |batch: bool| -> f64 {
+            let t0 = Instant::now();
+            black_box(build(22, 2, batch));
+            t0.elapsed().as_secs_f64()
+        };
+        for _ in 0..3 {
+            black_box(time(true));
+            black_box(time(false));
+        }
+        let median = |v: &[f64]| {
+            let mut s = v.to_vec();
+            s.sort_by(|a, b| a.partial_cmp(b).unwrap());
+            s[s.len() / 2]
+        };
+        let rounds = 61usize;
+        let paired = |cand: bool, base_arm: bool| -> Vec<f64> {
+            let mut v = Vec::with_capacity(rounds);
+            for round in 0..rounds {
+                let (tb, tc) = if round.is_multiple_of(2) {
+                    let bt = time(base_arm);
+                    let ct = time(cand);
+                    (bt, ct)
+                } else {
+                    let ct = time(cand);
+                    let bt = time(base_arm);
+                    (bt, ct)
+                };
+                v.push(tb / tc);
+            }
+            v
+        };
+        let report = |name: &str, ratios: &[f64]| {
+            let wins = ratios.iter().filter(|&&r| r > 1.0).count();
+            let mut sorted = ratios.to_vec();
+            sorted.sort_by(|a, b| a.partial_cmp(b).unwrap());
+            println!(
+                "KNESER_BATCH_AB {name}: median={:.4}x win_rate={wins}/{rounds} \
+                 p5_p95=[{:.4},{:.4}]",
+                median(ratios),
+                sorted[rounds * 5 / 100],
+                sorted[rounds * 95 / 100],
+            );
+        };
+        println!("KNESER_BATCH_AB KG22_2 rounds={rounds} (>1 = batch faster)");
+        report("BATCH_vs_string", &paired(true, false));
+        report("NULL_batch_vs_batch", &paired(true, true));
+    }
+
