+    /// br-r37-c1-gparm: paired-interleaved median A/B for the integer-adjacency
+    /// `global_parameters` vs the old `graph.neighbors()` (`Vec<&str>`) + `idx.get`
+    /// String baseline, in ONE binary / ONE worker with a NULL control. `#[ignore]`
+    /// (measurement); run with
+    /// `cargo test --release -p fnx-algorithms --lib global_parameters_gparm_ab -- --ignored --nocapture`.
+    #[test]
+    #[ignore = "measurement; run with --release --ignored --nocapture"]
+    fn global_parameters_gparm_ab() {
+        use std::hint::black_box;
+        use std::time::Instant;
+
+        // Complete graph K_n is distance-regular (diameter 1), so global_parameters
+        // runs the full O(V²·deg) count pass and returns Some — exercising exactly
+        // the path where the baseline allocs a Vec<&str> + idx.get-hashes every
+        // neighbour of every node. n=110.
+        let build_complete = |n: usize| {
+            let mut g = Graph::strict();
+            for i in 0..n {
+                let _ = g.add_node(format!("k{i}"));
+            }
+            for i in 0..n {
+                for j in (i + 1)..n {
+                    let _ = g.add_edge(format!("k{i}"), format!("k{j}"));
+                }
+            }
+            g
+        };
+        let g = build_complete(110);
+
+        // Parity across the Some path (K_n, C_m distance-regular) and the None path
+        // (a path graph, not distance-regular).
+        let mut cyc = Graph::strict();
+        for i in 0..20usize {
+            let _ = cyc.add_node(format!("c{i}"));
+        }
+        for i in 0..20usize {
+            let _ = cyc.add_edge(format!("c{i}"), format!("c{}", (i + 1) % 20));
+        }
+        let mut path = Graph::strict();
+        for i in 0..20usize {
+            let _ = path.add_node(format!("p{i}"));
+        }
+        for i in 0..19usize {
+            let _ = path.add_edge(format!("p{i}"), format!("p{}", i + 1));
+        }
+        for gr in [&g, &cyc, &path] {
+            assert_eq!(
+                super::global_parameters(gr),
+                super::global_parameters_orig_string(gr),
+                "integer global_parameters must equal the String baseline"
+            );
+        }
+
+        let time = |lever: bool| -> f64 {
+            let t0 = Instant::now();
+            if lever {
+                black_box(super::global_parameters(&g));
+            } else {
+                black_box(super::global_parameters_orig_string(&g));
+            }
+            t0.elapsed().as_secs_f64()
+        };
+        for _ in 0..2 {
+            black_box(time(true));
+            black_box(time(false));
+        }
+        let median = |v: &[f64]| {
+            let mut s = v.to_vec();
+            s.sort_by(|a, b| a.partial_cmp(b).unwrap());
+            s[s.len() / 2]
+        };
+        let rounds = 61usize;
+        let paired = |cand: bool, base: bool| -> Vec<f64> {
+            let mut v = Vec::with_capacity(rounds);
+            for r in 0..rounds {
+                let (tb, tc) = if r % 2 == 0 {
+                    let b = time(base);
+                    let c = time(cand);
+                    (b, c)
+                } else {
+                    let c = time(cand);
+                    let b = time(base);
+                    (b, c)
+                };
+                v.push(tb / tc);
+            }
+            v
+        };
+        let report = |name: &str, ratios: &[f64]| {
+            let wins = ratios.iter().filter(|&&r| r > 1.0).count();
+            let mut sorted = ratios.to_vec();
+            sorted.sort_by(|a, b| a.partial_cmp(b).unwrap());
+            println!(
+                "GPARM_AB {name}: median={:.4}x win_rate={wins}/{rounds} \
+                 p5_p95=[{:.4},{:.4}]",
+                median(ratios),
+                sorted[rounds * 5 / 100],
+                sorted[rounds * 95 / 100],
+            );
+        };
+        println!("GPARM_AB n=110 (K_n complete) rounds={rounds} (>1 = integer faster)");
+        report("INT_vs_string", &paired(true, false));
+        report("NULL_int_vs_int", &paired(true, true));
+    }
