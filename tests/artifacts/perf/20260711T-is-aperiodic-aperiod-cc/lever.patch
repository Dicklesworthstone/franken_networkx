 /// A general digraph is aperiodic if every strongly connected component is aperiodic.
 #[must_use]
 pub fn is_aperiodic(digraph: &DiGraph) -> bool {
+    let n = digraph.node_count();
+    if n == 0 {
+        return true;
+    }
+    // Get SCCs
+    let sccs = strongly_connected_components(digraph);
+    if sccs.is_empty() {
+        return true;
+    }
+
+    // br-r37-c1-aperiod (cc): the per-SCC BFS that computes the GCD of cycle lengths
+    // ran on a String-keyed `HashMap<&str, usize>` `dist` + `HashSet<&str>` `scc_set`
+    // and called `successors(u)` (a `Vec<&str>` alloc per pop). Mark the SCC in a
+    // reusable `in_scc` array, key `dist`/`visited` by node index, and walk
+    // `successors_indices(u)`. Byte-identical: `successors_indices` yields the same
+    // successor order as `successors`, so the BFS visits identically → identical
+    // `dist`, identical tree/back-edge classification, identical `cycle_len` sequence
+    // (including the pre-existing usize wraparound when a back edge points one level
+    // ahead, which yields `cycle_len == 0` and `gcd(x, 0) == x`), and `gcd` is
+    // commutative+associative anyway. `strongly_connected_components` unchanged.
+    let mut in_scc = vec![false; n];
+    let mut visited = vec![false; n];
+    let mut dist = vec![0usize; n];
+    for scc in &sccs {
+        if scc.len() <= 1 {
+            continue;
+        }
+        let scc_idx: Vec<usize> = scc
+            .iter()
+            .filter_map(|name| digraph.get_node_index(name))
+            .collect();
+        for &ci in &scc_idx {
+            in_scc[ci] = true;
+        }
+        let start = scc_idx[0];
+        visited[start] = true;
+        dist[start] = 0;
+        let mut queue = VecDeque::new();
+        queue.push_back(start);
+        let mut gcd_val = 0usize;
+        while let Some(u) = queue.pop_front() {
+            let d_u = dist[u];
+            if let Some(succs) = digraph.successors_indices(u) {
+                for &s in succs {
+                    if !in_scc[s] {
+                        continue;
+                    }
+                    if visited[s] {
+                        // Back edge: cycle length = d_u - d_s + 1
+                        let cycle_len = d_u - dist[s] + 1;
+                        gcd_val = gcd(gcd_val, cycle_len);
+                    } else {
+                        visited[s] = true;
+                        dist[s] = d_u + 1;
+                        queue.push_back(s);
+                    }
+                }
+            }
+        }
+        for &ci in &scc_idx {
+            in_scc[ci] = false;
+            visited[ci] = false;
+        }
+        if gcd_val != 1 {
+            return false;
+        }
+    }
+    true
+}
