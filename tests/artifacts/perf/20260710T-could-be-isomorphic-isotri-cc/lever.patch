+/// br-r37-c1-isotri: per-node triangle counts for `could_be_isomorphic`, returned
+/// in `nodes_ordered()` order.
+///
+/// Integer-adjacency + reusable mark-array kernel: for each node `u`, mark its
+/// neighbour set in `in_nbrs`, then count the `(nbr, nn)` pairs with `nbr ∈ N(u)`,
+/// `nn ∈ N(nbr)`, `nn ∈ N(u)`, and `nn` ordered after `nbr` — i.e. the number of
+/// intra-ego edges, which is exactly the number of triangles through `u`.
+///
+/// Byte-identical to the old string kernel: the triangle count through a node is
+/// the count of edges within its neighbourhood, and requiring `nn > nbr` selects
+/// each such edge exactly once under ANY total order on the endpoints. Switching
+/// the tie-break from lexicographic name order to integer-index order therefore
+/// leaves every per-node count unchanged (asserted equal in-test).
+fn could_be_isomorphic_triangle_counts(graph: &Graph) -> Vec<usize> {
+    let n = graph.node_count();
+    let mut counts = vec![0usize; n];
+    let mut in_nbrs = vec![false; n];
+    for u in 0..n {
+        let nbrs_u = graph.neighbors_indices(u).unwrap_or(&[]);
+        for &x in nbrs_u {
+            in_nbrs[x] = true;
+        }
