+    /// br-r37-c1-linegraphdirbatch: paired-interleaved median A/B for line_graph_directed — inline
+    /// per-edge baseline vs the shipped batch, one binary / one worker with a NULL control. Byte-identity
+    /// asserted first. `#[ignore]`; run with
+    /// `cargo test --release -p fnx-algorithms --lib line_graph_directed_batch_ab -- --ignored --nocapture`.
+    #[test]
+    #[ignore = "measurement; run with --release --ignored --nocapture"]
+    fn line_graph_directed_batch_ab() {
+        use super::pair_label;
+        use std::hint::black_box;
+        use std::time::Instant;
+
+        // Complete digraph K30 (870 directed edges) → dense directed line graph.
+        let mut input = DiGraph::strict();
+        let m = 30usize;
+        for i in 0..m {
+            let _ = input.add_node(format!("{i}"));
+        }
+        for i in 0..m {
+            for j in 0..m {
+                if i != j {
+                    let _ = input.add_edge(format!("{i}"), format!("{j}"));
+                }
+            }
+        }
+
+        let build = |g: &DiGraph, batch: bool| -> DiGraph {
+            let mut result = DiGraph::with_runtime_policy(g.runtime_policy().clone());
+            let edges: Vec<(String, String)> = g
+                .edges_ordered()
+                .into_iter()
+                .map(|e| (e.left.clone(), e.right.clone()))
+                .collect();
+            for (u, v) in &edges {
+                let _ = result.add_node(pair_label(u, v));
+            }
+            if batch {
+                let mut result_edges: Vec<(String, String)> = Vec::new();
+                for (u, v) in &edges {
+                    let from_node = pair_label(u, v);
+                    for (u2, v2) in &edges {
+                        if v == u2 {
+                            result_edges.push((from_node.clone(), pair_label(u2, v2)));
+                        }
+                    }
+                }
+                let _ = result.extend_edges_unrecorded(result_edges);
+            } else {
+                for (u, v) in &edges {
+                    let from_node = pair_label(u, v);
+                    for (u2, v2) in &edges {
+                        if v == u2 {
+                            let to_node = pair_label(u2, v2);
+                            let _ = result.add_edge(from_node.clone(), to_node);
+                        }
+                    }
+                }
+            }
+            result
+        };
+
+        let old = build(&input, false);
+        let new = build(&input, true);
+        assert_eq!(
+            old.edges_ordered_borrowed(),
+            new.edges_ordered_borrowed(),
+            "batch line_graph_directed must equal the per-edge baseline"
+        );
+        assert_eq!(old.nodes_ordered(), new.nodes_ordered());
+
+        let time = |batch: bool| -> f64 {
+            let t0 = Instant::now();
+            black_box(build(&input, batch));
+            t0.elapsed().as_secs_f64()
+        };
+        for _ in 0..3 {
+            black_box(time(true));
+            black_box(time(false));
+        }
+        let median = |v: &[f64]| {
+            let mut s = v.to_vec();
+            s.sort_by(|a, b| a.partial_cmp(b).unwrap());
+            s[s.len() / 2]
+        };
+        let rounds = 61usize;
+        let paired = |cand: bool, base_arm: bool| -> Vec<f64> {
+            let mut v = Vec::with_capacity(rounds);
+            for round in 0..rounds {
+                let (tb, tc) = if round.is_multiple_of(2) {
+                    let bt = time(base_arm);
+                    let ct = time(cand);
+                    (bt, ct)
+                } else {
+                    let ct = time(cand);
+                    let bt = time(base_arm);
+                    (bt, ct)
+                };
+                v.push(tb / tc);
+            }
+            v
+        };
+        let report = |name: &str, ratios: &[f64]| {
+            let wins = ratios.iter().filter(|&&r| r > 1.0).count();
+            let mut sorted = ratios.to_vec();
+            sorted.sort_by(|a, b| a.partial_cmp(b).unwrap());
+            println!(
+                "LINEGRAPHDIR_BATCH_AB {name}: median={:.4}x win_rate={wins}/{rounds} \
+                 p5_p95=[{:.4},{:.4}]",
+                median(ratios),
+                sorted[rounds * 5 / 100],
+                sorted[rounds * 95 / 100],
+            );
+        };
+        println!("LINEGRAPHDIR_BATCH_AB dK30 rounds={rounds} (>1 = batch faster)");
+        report("BATCH_vs_string", &paired(true, false));
+        report("NULL_batch_vs_batch", &paired(true, true));
+    }
+
