+    /// br-r37-c1-powerbatch: paired-interleaved median A/B for power's edge insertion — inline per-edge
+    /// baseline vs the shipped batch, one binary / one worker with a NULL control. The per-source BFS is
+    /// common to both arms; only the power-edge insertion differs. Byte-identity asserted first.
+    /// `#[ignore]`; run with
+    /// `cargo test --release -p fnx-algorithms --lib power_batch_ab -- --ignored --nocapture`.
+    #[test]
+    #[ignore = "measurement; run with --release --ignored --nocapture"]
+    fn power_batch_ab() {
+        use std::collections::{HashMap, VecDeque};
+        use std::hint::black_box;
+        use std::time::Instant;
+
+        // K120, k=1 → power = K120 (7140 output edges).
+        let mut input = Graph::strict();
+        let m = 120usize;
+        for i in 0..m {
+            let _ = input.add_node(format!("{i}"));
+        }
+        for i in 0..m {
+            for j in (i + 1)..m {
+                let _ = input.add_edge(format!("{i}"), format!("{j}"));
+            }
+        }
+        let k = 1usize;
+
+        let build = |g: &Graph, k: usize, batch: bool| -> Graph {
+            let nodes = g.nodes_ordered();
+            let n = nodes.len();
+            let idx: HashMap<&str, usize> =
+                nodes.iter().enumerate().map(|(i, nn)| (*nn, i)).collect();
+            let mut result = Graph::with_runtime_policy(g.runtime_policy().clone());
+            for &node in &nodes {
+                let _ = result.add_node(node.to_owned());
+            }
+            let mut edges: Vec<(String, String)> = Vec::new();
+            for s in 0..n {
+                let mut dist = vec![usize::MAX; n];
+                dist[s] = 0;
+                let mut queue = VecDeque::new();
+                queue.push_back(s);
+                while let Some(v) = queue.pop_front() {
+                    let d = dist[v];
+                    if d >= k {
+                        continue;
+                    }
+                    if let Some(nbrs) = g.neighbors(nodes[v]) {
+                        for nb in nbrs {
+                            if let Some(&ni) = idx.get(nb)
+                                && dist[ni] == usize::MAX
+                            {
+                                dist[ni] = d + 1;
+                                queue.push_back(ni);
+                                if ni > s {
+                                    if batch {
+                                        edges.push((nodes[s].to_owned(), nodes[ni].to_owned()));
+                                    } else {
+                                        let _ = result
+                                            .add_edge(nodes[s].to_owned(), nodes[ni].to_owned());
+                                    }
+                                }
+                            }
+                        }
+                    }
+                }
+            }
+            if batch {
+                let _ = result.extend_edges_unrecorded(edges);
+            }
+            result
+        };
+
+        let old = build(&input, k, false);
+        let new = build(&input, k, true);
+        assert_eq!(
+            old.edges_ordered_borrowed(),
+            new.edges_ordered_borrowed(),
+            "batch power must equal the per-edge baseline"
+        );
+        assert_eq!(old.nodes_ordered(), new.nodes_ordered());
+
+        let time = |batch: bool| -> f64 {
+            let t0 = Instant::now();
+            black_box(build(&input, k, batch));
+            t0.elapsed().as_secs_f64()
+        };
+        for _ in 0..3 {
+            black_box(time(true));
+            black_box(time(false));
+        }
+        let median = |v: &[f64]| {
+            let mut s = v.to_vec();
+            s.sort_by(|a, b| a.partial_cmp(b).unwrap());
+            s[s.len() / 2]
+        };
+        let rounds = 61usize;
+        let paired = |cand: bool, base_arm: bool| -> Vec<f64> {
+            let mut v = Vec::with_capacity(rounds);
+            for round in 0..rounds {
+                let (tb, tc) = if round.is_multiple_of(2) {
+                    let bt = time(base_arm);
+                    let ct = time(cand);
+                    (bt, ct)
+                } else {
+                    let ct = time(cand);
+                    let bt = time(base_arm);
+                    (bt, ct)
+                };
+                v.push(tb / tc);
+            }
+            v
+        };
+        let report = |name: &str, ratios: &[f64]| {
+            let wins = ratios.iter().filter(|&&r| r > 1.0).count();
+            let mut sorted = ratios.to_vec();
+            sorted.sort_by(|a, b| a.partial_cmp(b).unwrap());
+            println!(
+                "POWER_BATCH_AB {name}: median={:.4}x win_rate={wins}/{rounds} \
+                 p5_p95=[{:.4},{:.4}]",
+                median(ratios),
+                sorted[rounds * 5 / 100],
+                sorted[rounds * 95 / 100],
+            );
+        };
+        println!("POWER_BATCH_AB K120_k1 rounds={rounds} (>1 = batch faster)");
+        report("BATCH_vs_string", &paired(true, false));
+        report("NULL_batch_vs_batch", &paired(true, true));
+    }
+
