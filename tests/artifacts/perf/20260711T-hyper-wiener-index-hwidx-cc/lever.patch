 /// Hyper-Wiener index over unordered node pairs.
 #[must_use]
 pub fn hyper_wiener_index(graph: &Graph) -> Option<f64> {
+    let n = graph.node_count();
+    if n < 2 {
+        return Some(0.0);
+    }
+
+    // br-r37-c1-hwidx (cc): all-pairs BFS, distance-metric family sibling of gutman/
+    // schultz. Walk `graph.neighbors_indices(v)` (zero-alloc `&[usize]`) instead of
+    // `graph.neighbors(nodes[v])` (a `Vec<&str>` alloc per pop) + `idx.get(nb)` String
+    // hash; `idx` and `nodes` dropped. Byte-identical: BFS distances are
+    // order-independent shortest paths, and `total` sums `d + d*d` (`d = dist[t] as
+    // f64`) in the SAME fixed (s asc, t asc) order over the same integer distances —
+    // no floating-point reassociation.
+    let mut total = 0.0;
+    for s in 0..n {
+        let mut dist = vec![usize::MAX; n];
+        dist[s] = 0;
+        let mut queue = std::collections::VecDeque::new();
+        queue.push_back(s);
+        while let Some(v) = queue.pop_front() {
+            if let Some(nbrs) = graph.neighbors_indices(v) {
+                for &ni in nbrs {
+                    if dist[ni] == usize::MAX {
+                        dist[ni] = dist[v] + 1;
+                        queue.push_back(ni);
+                    }
+                }
+            }
+        }
+        if dist.contains(&usize::MAX) {
+            return None;
+        }
+        for t in (s + 1)..n {
+            let d = dist[t] as f64;
+            total += d + d * d;
+        }
+    }
+    Some(total)
+}
