 /// Matches `networkx.in_degree_centrality(G)`.
 #[must_use]
 pub fn in_degree_centrality(digraph: &DiGraph) -> Vec<CentralityScore> {
+    let nodes = digraph.nodes_ordered();
+    let n = nodes.len();
+    if n == 0 {
+        return Vec::new();
+    }
+    if n == 1 {
+        return nodes
+            .iter()
+            .map(|&node| CentralityScore {
+                node: node.to_owned(),
+                score: 1.0,
+            })
+            .collect();
+    }
+    let denom = (n - 1) as f64;
+    // br-r37-c1-idc (cc): no-alloc in-degree via `in_degree_by_index(i)` instead of
+    // `predecessors(node)` (a `Vec<&str>` alloc just to take `.len()`). Byte-identical:
+    // `in_degree_by_index(i) == predecessors(nodes[i]).len()`; `node.to_owned()` and the
+    // `in_deg / denom` score are unchanged. Directed twin of br-r37-c1-odc — the per-node
+    // `Vec<&str>` alloc dominates the per-node String clone, so this is a clean win.
+    nodes
+        .iter()
+        .enumerate()
+        .map(|(i, &node)| {
+            let in_deg = digraph.in_degree_by_index(i);
+            CentralityScore {
+                node: node.to_owned(),
+                score: in_deg as f64 / denom,
+            }
+        })
+        .collect()
+}
