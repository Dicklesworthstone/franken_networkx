+    fn faster_could_be_iso_eordlen_ab() {
+        use std::hint::black_box;
+        use std::time::Instant;
+
+        // Two large, dense-ish graphs with identical order AND size (so the function runs fully).
+        let n_nodes = 10000usize;
+        let build = || -> Graph {
+            let mut g = Graph::strict();
+            for i in 0..n_nodes {
+                let _ = g.add_node(i.to_string());
+            }
+            // ~20 edges/node ring-of-chords → ~100k edges; equal for both graphs.
+            for i in 0..n_nodes {
