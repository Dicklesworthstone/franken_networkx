+    /// br-r37-c1-clvit1: paired-interleaved median A/B for the full-index integer-BFS
+    /// `closeness_vitality_single` vs the old per-excluded `HashMap<&str,usize>` +
+    /// `graph.neighbors()` (`Vec<&str>`) String baseline, in ONE binary / ONE worker
+    /// with a NULL control. `#[ignore]` (measurement); run with
+    /// `cargo test --release -p fnx-algorithms --lib closeness_vitality_single_clvit1_ab -- --ignored --nocapture`.
+    #[test]
+    #[ignore = "measurement; run with --release --ignored --nocapture"]
+    fn closeness_vitality_single_clvit1_ab() {
+        use std::hint::black_box;
+        use std::time::Instant;
+
+        // closeness_vitality_single(node) BFSes from every remaining node in the
+        // subgraph without `node` — O(V·(V+E)). Well-connected n=200 graph (spanning
+        // path + random edges) so the removal stays connected and does full work.
+        let n = 200usize;
+        let deg = 10usize;
+        let mut g = Graph::strict();
+        for i in 0..n {
+            let _ = g.add_node(format!("n{i}"));
+        }
+        for i in 0..n.saturating_sub(1) {
+            let _ = g.add_edge(format!("n{i}"), format!("n{}", i + 1));
+        }
+        for i in 0..n {
+            for k in 1..=deg {
+                let j = ((i as u64)
+                    .wrapping_mul(1_000_003)
+                    .wrapping_add((k as u64).wrapping_mul(97))
+                    % n as u64) as usize;
+                if j != i {
+                    let _ = g.add_edge(format!("n{i}"), format!("n{j}"));
+                }
+            }
+        }
+        let target = "n100";
+
+        // Byte-exact parity: full-index integer vitality == String baseline.
+        let mark = super::closeness_vitality_single(&g, target);
+        let base = super::closeness_vitality_single_orig_string(&g, target);
+        assert_eq!(
+            mark, base,
+            "integer closeness_vitality_single must equal the String baseline"
+        );
+
+        let time = |lever: bool| -> f64 {
+            let t0 = Instant::now();
+            for _ in 0..2 {
+                if lever {
+                    black_box(super::closeness_vitality_single(&g, target));
+                } else {
+                    black_box(super::closeness_vitality_single_orig_string(&g, target));
+                }
+            }
+            t0.elapsed().as_secs_f64()
+        };
+        for _ in 0..2 {
+            black_box(time(true));
+            black_box(time(false));
+        }
+        let median = |v: &[f64]| {
+            let mut s = v.to_vec();
+            s.sort_by(|a, b| a.partial_cmp(b).unwrap());
+            s[s.len() / 2]
+        };
+        let rounds = 61usize;
+        let paired = |cand: bool, base: bool| -> Vec<f64> {
+            let mut v = Vec::with_capacity(rounds);
+            for r in 0..rounds {
+                let (tb, tc) = if r % 2 == 0 {
+                    let b = time(base);
+                    let c = time(cand);
+                    (b, c)
+                } else {
+                    let c = time(cand);
+                    let b = time(base);
+                    (b, c)
+                };
+                v.push(tb / tc);
+            }
+            v
+        };
+        let report = |name: &str, ratios: &[f64]| {
