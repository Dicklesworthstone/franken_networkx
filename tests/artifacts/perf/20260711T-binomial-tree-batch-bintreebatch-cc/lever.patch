+    /// br-r37-c1-bintreebatch: paired-interleaved median A/B for binomial_tree edge insertion —
+    /// batch-by-index vs the per-edge `add_edge`, one binary / one worker with a NULL control. The
+    /// binomial tree accumulates its edges as index pairs already; deterministic, 2^n-1 edges (tree).
+    /// Byte-identity checked via parity asserts. `#[ignore]`; run with
+    /// `cargo test --release -p fnx-generators --lib binomial_tree_batch_ab -- --ignored --nocapture`.
+    #[test]
+    #[ignore = "measurement; run with --release --ignored --nocapture"]
+    fn binomial_tree_batch_ab() {
+        use super::graph_with_n_nodes;
+        use std::hint::black_box;
+        use std::time::Instant;
+
+        let collect_pairs = |order: usize| -> Vec<(usize, usize)> {
+            let node_count = 1usize << order;
+            let mut edges = Vec::<(usize, usize)>::with_capacity(node_count.saturating_sub(1));
+            let mut tree_size = 1usize;
+            for _ in 0..order {
+                let shifted = edges
+                    .iter()
+                    .map(|&(l, r)| (l + tree_size, r + tree_size))
+                    .collect::<Vec<(usize, usize)>>();
+                edges.extend(shifted);
+                edges.push((0, tree_size));
+                tree_size *= 2;
+            }
+            edges
+        };
+
+        let build_string = |order: usize| {
+            let node_count = 1usize << order;
+            let (mut g, node_labels) = graph_with_n_nodes(CompatibilityMode::Strict, node_count);
+            for &(l, r) in &collect_pairs(order) {
+                let _ = g.add_edge(node_labels[l].clone(), node_labels[r].clone());
+            }
+            g
+        };
+        let build_batch = |order: usize| {
+            let node_count = 1usize << order;
+            let (mut g, _node_labels) = graph_with_n_nodes(CompatibilityMode::Strict, node_count);
+            let _ = g.extend_existing_index_edges_unrecorded(collect_pairs(order));
+            g
+        };
+
+        // Byte-identity across orders (construction only, no timing) — small multi-digit label
+        // orders exercise the name-vs-index canonicalization difference.
+        for &order in &[0usize, 1, 2, 5, 10, 16] {
+            let gs = build_string(order);
+            let gb = build_batch(order);
+            assert_eq!(
+                gs.edges_ordered_borrowed(),
+                gb.edges_ordered_borrowed(),
+                "batch-by-index binomial_tree(order={order}) must equal the per-edge baseline"
+            );
+            assert_eq!(gs.nodes_ordered(), gb.nodes_ordered(), "nodes order={order}");
+        }
+
+        // binomial_tree(16): 65536 nodes, 65535 edges.
+        let order = 16usize;
+        let time = |batch: bool| -> f64 {
+            let t0 = Instant::now();
+            if batch {
+                black_box(build_batch(order));
+            } else {
+                black_box(build_string(order));
+            }
+            t0.elapsed().as_secs_f64()
+        };
+        for _ in 0..3 {
+            black_box(time(true));
+            black_box(time(false));
+        }
+        let median = |v: &[f64]| {
+            let mut s = v.to_vec();
+            s.sort_by(|a, b| a.partial_cmp(b).unwrap());
+            s[s.len() / 2]
+        };
+        let rounds = 61usize;
+        let paired = |cand: bool, base_arm: bool| -> Vec<f64> {
+            let mut v = Vec::with_capacity(rounds);
+            for round in 0..rounds {
+                let (tb, tc) = if round % 2 == 0 {
+                    let bt = time(base_arm);
+                    let ct = time(cand);
+                    (bt, ct)
+                } else {
+                    let ct = time(cand);
+                    let bt = time(base_arm);
+                    (bt, ct)
+                };
+                v.push(tb / tc);
+            }
+            v
+        };
+        let report = |name: &str, ratios: &[f64]| {
+            let wins = ratios.iter().filter(|&&r| r > 1.0).count();
+            let mut sorted = ratios.to_vec();
+            sorted.sort_by(|a, b| a.partial_cmp(b).unwrap());
+            println!(
+                "BINTREE_BATCH_AB {name}: median={:.4}x win_rate={wins}/{rounds} \
+                 p5_p95=[{:.4},{:.4}]",
+                median(ratios),
+                sorted[rounds * 5 / 100],
+                sorted[rounds * 95 / 100],
+            );
+        };
+        println!("BINTREE_BATCH_AB order={order} rounds={rounds} (>1 = batch faster)");
+        report("BATCH_vs_string", &paired(true, false));
+        report("NULL_batch_vs_batch", &paired(true, true));
+    }
+
