+        // reachability and returns true.
+        let n = 50000usize;
+        let mut g = DiGraph::strict();
+        for i in 0..n {
+            let _ = g.add_node(format!("n{i}"));
+        }
+        for i in 0..n {
+            let _ = g.add_edge(format!("n{i}"), format!("n{}", (i + 1) % n));
+        }
+        let names: Vec<String> = (0..n).map(|i| format!("n{i}")).collect();
+        let comp: Vec<&str> = names.iter().map(String::as_str).collect();
