+    fn is_attracting_component_attract_ab() {
+        use std::hint::black_box;
+        use std::time::Instant;
+
+        // A single directed cycle on n=50000 (i -> (i+1)%n): the whole graph is one
+        // strongly connected attracting component (no edge leaves it). Passing all n
