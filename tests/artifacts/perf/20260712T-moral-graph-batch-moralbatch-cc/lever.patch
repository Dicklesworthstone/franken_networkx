+    /// br-r37-c1-moralbatch: paired-interleaved median A/B for moral_graph — inline per-edge baseline vs
+    /// the shipped batch, one binary / one worker with a NULL control. A bipartite DAG (60 parents -> 60
+    /// children) makes the co-parent phase contribute ~106k edges that dedup to 1770, so the per-edge
+    /// policy record on every (dup) add_edge is the cost the batch removes. Byte-identity asserted first.
+    /// `#[ignore]`; run with
+    /// `cargo test --release -p fnx-algorithms --lib moral_graph_batch_ab -- --ignored --nocapture`.
+    #[test]
+    #[ignore = "measurement; run with --release --ignored --nocapture"]
+    fn moral_graph_batch_ab() {
+        use std::hint::black_box;
+        use std::time::Instant;
+
+        // Bipartite DAG: parents 0..60 each point to children 60..120.
+        let mut input = DiGraph::strict();
+        for i in 0..120 {
+            let _ = input.add_node(format!("{i}"));
+        }
+        for p in 0..60 {
+            for c in 60..120 {
+                let _ = input.add_edge(format!("{p}"), format!("{c}"));
+            }
+        }
+
+        let build = |g: &DiGraph, batch: bool| -> Graph {
+            let mut result = Graph::with_runtime_policy(g.runtime_policy().clone());
+            for node in g.nodes_ordered() {
+                let _ = result.add_node(node.to_owned());
+            }
+            if batch {
+                let mut edges: Vec<(String, String)> = Vec::new();
+                for edge in g.edges_ordered() {
+                    edges.push((edge.left.clone(), edge.right.clone()));
+                }
+                for node in g.nodes_ordered() {
+                    if let Some(preds) = g.predecessors(node) {
+                        let parents: Vec<String> = preds.iter().map(|p| (*p).to_owned()).collect();
+                        for i in 0..parents.len() {
+                            for j in (i + 1)..parents.len() {
+                                edges.push((parents[i].clone(), parents[j].clone()));
+                            }
+                        }
+                    }
+                }
+                let _ = result.extend_edges_unrecorded(edges);
+            } else {
+                for edge in g.edges_ordered() {
+                    let _ = result.add_edge(edge.left.clone(), edge.right.clone());
+                }
+                for node in g.nodes_ordered() {
+                    if let Some(preds) = g.predecessors(node) {
+                        let parents: Vec<String> = preds.iter().map(|p| (*p).to_owned()).collect();
+                        for i in 0..parents.len() {
+                            for j in (i + 1)..parents.len() {
+                                let _ = result.add_edge(parents[i].clone(), parents[j].clone());
+                            }
+                        }
+                    }
+                }
+            }
+            result
+        };
+
+        let old = build(&input, false);
+        let new = build(&input, true);
+        assert_eq!(
+            old.edges_ordered_borrowed(),
+            new.edges_ordered_borrowed(),
+            "batch moral_graph must equal the per-edge baseline"
+        );
+        assert_eq!(old.nodes_ordered(), new.nodes_ordered());
+
+        let time = |batch: bool| -> f64 {
+            let t0 = Instant::now();
+            black_box(build(&input, batch));
+            t0.elapsed().as_secs_f64()
+        };
+        for _ in 0..3 {
+            black_box(time(true));
+            black_box(time(false));
+        }
+        let median = |v: &[f64]| {
+            let mut s = v.to_vec();
+            s.sort_by(|a, b| a.partial_cmp(b).unwrap());
+            s[s.len() / 2]
+        };
+        let rounds = 61usize;
+        let paired = |cand: bool, base_arm: bool| -> Vec<f64> {
+            let mut v = Vec::with_capacity(rounds);
+            for round in 0..rounds {
+                let (tb, tc) = if round.is_multiple_of(2) {
+                    let bt = time(base_arm);
+                    let ct = time(cand);
+                    (bt, ct)
+                } else {
+                    let ct = time(cand);
+                    let bt = time(base_arm);
+                    (bt, ct)
+                };
+                v.push(tb / tc);
+            }
+            v
+        };
+        let report = |name: &str, ratios: &[f64]| {
+            let wins = ratios.iter().filter(|&&r| r > 1.0).count();
+            let mut sorted = ratios.to_vec();
+            sorted.sort_by(|a, b| a.partial_cmp(b).unwrap());
+            println!(
+                "MORAL_BATCH_AB {name}: median={:.4}x win_rate={wins}/{rounds} \
+                 p5_p95=[{:.4},{:.4}]",
+                median(ratios),
+                sorted[rounds * 5 / 100],
+                sorted[rounds * 95 / 100],
+            );
+        };
+        println!("MORAL_BATCH_AB bipartite60x60 rounds={rounds} (>1 = batch faster)");
+        report("BATCH_vs_string", &paired(true, false));
+        report("NULL_batch_vs_batch", &paired(true, true));
+    }
+
