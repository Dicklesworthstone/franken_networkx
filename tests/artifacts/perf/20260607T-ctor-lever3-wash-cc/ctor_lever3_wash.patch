     /// Callers MUST pre-screen attr keys starting with
     /// `"__fnx_incompatible"` and route those edges through
     /// `add_edge_with_attrs`, which owns the FailClosed contract for them.
+    /// br-r37-c1-d58s8 ctor absorb lever: bulk edge insert by NODE
+    /// INDICES — zero Strings in the edge stream (callers resolve
+    /// endpoints to indices once per unique node; the index-keyed edges
+    /// map makes the whole path integer). Same merge/dedup semantics as
+    /// extend_edges_with_attrs_unrecorded; indices MUST be valid (the
+    /// caller created the nodes first).
+    pub fn extend_edges_by_indices_unrecorded<I>(&mut self, edges: I) -> usize
+    where
+        I: IntoIterator<Item = (usize, usize, AttrMap)>,
+    {
+        let iterator = edges.into_iter();
+        let (lower_bound, _) = iterator.size_hint();
+        self.edges.reserve(lower_bound);
+        self.edge_index_endpoints.reserve(lower_bound);
+
+        let mut inserted = 0usize;
+        let mut merged_changed = false;
+        for (left_idx, right_idx, attrs) in iterator {
+            debug_assert!(left_idx < self.nodes.len() && right_idx < self.nodes.len());
+            let edge_key = Self::canon_pair(left_idx, right_idx);
+            match self.edges.entry(edge_key) {
+                indexmap::map::Entry::Occupied(mut occupied) => {
+                    let existing = occupied.get_mut();
+                    if !attrs.is_empty()
+                        && attrs
+                            .iter()
+                            .any(|(key, value)| existing.get(key) != Some(value))
+                    {
+                        merged_changed = true;
+                    }
+                    existing.extend(attrs);
+                    continue;
+                }
+                indexmap::map::Entry::Vacant(vacant) => {
+                    vacant.insert(attrs);
+                }
+            }
+            // endpoints orientation: STRING-canonical (matches the other
+            // writers — snapshot derivation depends on it).
+            let left_name = self.nodes.get_index(left_idx).expect("valid index").0;
+            let right_name = self.nodes.get_index(right_idx).expect("valid index").0;
+            if left_name <= right_name {
+                self.edge_index_endpoints.push((left_idx, right_idx));
+            } else {
+                self.edge_index_endpoints.push((right_idx, left_idx));
+            }
+            self.adj_indices[left_idx].push(right_idx);
+            if left_idx != right_idx {
+                self.adj_indices[right_idx].push(left_idx);
+            }
+            inserted += 1;
+        }
+        if merged_changed {
+            self.revision = self.revision.saturating_add(1);
+        }
+        self.record_bulk_edge_summary(inserted, merged_changed);
+        inserted
+    }
+
     pub fn extend_edges_with_attrs_unrecorded<I>(&mut self, edges: I) -> usize
     where
         I: IntoIterator<Item = (String, String, AttrMap)>,
