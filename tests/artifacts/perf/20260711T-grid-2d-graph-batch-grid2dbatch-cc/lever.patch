+    /// br-r37-c1-grid2dbatch: paired-interleaved median A/B for grid_2d_graph edge insertion —
+    /// batch-by-index vs the per-edge `add_edge`, one binary / one worker with a NULL control. Grid is
+    /// dense (~2mn edges), deterministic; the m>2/n>2 guards on the periodic wraps make every edge
+    /// unique (no dedup). Byte-identity checked across periodic/guard configs. `#[ignore]`; run with
+    /// `cargo test --release -p fnx-generators --lib grid_2d_batch_ab -- --ignored --nocapture`.
+    #[test]
+    #[ignore = "measurement; run with --release --ignored --nocapture"]
+    fn grid_2d_batch_ab() {
+        use std::hint::black_box;
+        use std::time::Instant;
+
+        let collect_pairs = |m: usize, n: usize, periodic: (bool, bool)| -> Vec<(usize, usize)> {
+            let mut edges: Vec<(usize, usize)> = Vec::new();
+            for row in 1..m {
+                for col in 0..n {
+                    edges.push(((row - 1) * n + col, row * n + col));
+                }
+            }
+            for row in 0..m {
+                for col in 1..n {
+                    edges.push((row * n + col - 1, row * n + col));
+                }
+            }
+            if periodic.0 && m > 2 {
+                for col in 0..n {
+                    edges.push((col, (m - 1) * n + col));
+                }
+            }
+            if periodic.1 && n > 2 {
+                for row in 0..m {
+                    edges.push((row * n, row * n + n - 1));
+                }
+            }
+            edges
+        };
+        let make_graph = |m: usize, n: usize| -> (Graph, Vec<String>) {
+            let mut g = Graph::new(CompatibilityMode::Strict);
+            let mut labels = Vec::with_capacity(m * n);
+            for row in 0..m {
+                for col in 0..n {
+                    let label = super::format_grid_2d_label(row, col);
+                    g.add_node(label.clone());
+                    labels.push(label);
+                }
+            }
+            (g, labels)
+        };
+
+        let build_string = |m: usize, n: usize, periodic: (bool, bool)| {
+            let (mut g, labels) = make_graph(m, n);
+            for &(l, r) in &collect_pairs(m, n, periodic) {
+                let _ = g.add_edge(labels[l].clone(), labels[r].clone());
+            }
+            g
+        };
+        let build_batch = |m: usize, n: usize, periodic: (bool, bool)| {
+            let (mut g, _labels) = make_graph(m, n);
+            let _ = g.extend_existing_index_edges_unrecorded(collect_pairs(m, n, periodic));
+            g
+        };
+
+        // Byte-identity across periodic modes + the m>2 / n>2 guard cases (construction only).
+        for &(m, n, periodic) in &[
+            (5usize, 7usize, (false, false)),
+            (5, 7, (true, true)),
+            (5, 7, (true, false)),
+            (5, 7, (false, true)),
+            (2, 7, (true, true)), // m==2 → row-wrap suppressed
+            (7, 2, (true, true)), // n==2 → col-wrap suppressed
+            (2, 2, (true, true)),
+            (300, 300, (false, false)),
+        ] {
+            let gs = build_string(m, n, periodic);
+            let gb = build_batch(m, n, periodic);
+            assert_eq!(
+                gs.edges_ordered_borrowed(),
+                gb.edges_ordered_borrowed(),
+                "batch-by-index grid_2d({m},{n},{periodic:?}) must equal the per-edge baseline"
+            );
+            assert_eq!(
+                gs.nodes_ordered(),
+                gb.nodes_ordered(),
+                "nodes grid_2d({m},{n})"
+            );
+        }
+
+        // grid_2d(300, 300, non-periodic): 90000 nodes, 2*300*299 = 179400 edges.
+        let (m, n, periodic) = (300usize, 300usize, (false, false));
+        let time = |batch: bool| -> f64 {
+            let t0 = Instant::now();
+            if batch {
+                black_box(build_batch(m, n, periodic));
+            } else {
+                black_box(build_string(m, n, periodic));
+            }
+            t0.elapsed().as_secs_f64()
+        };
+        for _ in 0..3 {
+            black_box(time(true));
+            black_box(time(false));
+        }
+        let median = |v: &[f64]| {
+            let mut s = v.to_vec();
+            s.sort_by(|a, b| a.partial_cmp(b).unwrap());
+            s[s.len() / 2]
+        };
+        let rounds = 61usize;
+        let paired = |cand: bool, base_arm: bool| -> Vec<f64> {
+            let mut v = Vec::with_capacity(rounds);
+            for round in 0..rounds {
+                let (tb, tc) = if round % 2 == 0 {
+                    let bt = time(base_arm);
+                    let ct = time(cand);
+                    (bt, ct)
+                } else {
+                    let ct = time(cand);
+                    let bt = time(base_arm);
+                    (bt, ct)
+                };
+                v.push(tb / tc);
+            }
+            v
+        };
+        let report = |name: &str, ratios: &[f64]| {
+            let wins = ratios.iter().filter(|&&r| r > 1.0).count();
+            let mut sorted = ratios.to_vec();
+            sorted.sort_by(|a, b| a.partial_cmp(b).unwrap());
+            println!(
+                "GRID2D_BATCH_AB {name}: median={:.4}x win_rate={wins}/{rounds} \
+                 p5_p95=[{:.4},{:.4}]",
+                median(ratios),
+                sorted[rounds * 5 / 100],
+                sorted[rounds * 95 / 100],
+            );
+        };
+        println!("GRID2D_BATCH_AB m={m} n={n} rounds={rounds} (>1 = batch faster)");
+        report("BATCH_vs_string", &paired(true, false));
+        report("NULL_batch_vs_batch", &paired(true, true));
+    }
+
