+/// worth nothing and traversal count is everything.)
+fn bitpar_chunk_lane_width(n: usize, threads: usize) -> usize {
+    (1..=8)
+        .rev()
+        .find(|w| n.div_ceil(64 * w) >= threads)
+        .unwrap_or(1)
