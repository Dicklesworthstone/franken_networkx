+    fn bench_low_diameter(n: usize, extra: usize) -> Graph {
+        let mut g = Graph::strict();
+        for i in 0..n {
+            let _ = g.add_node(i.to_string());
+        }
+        let mut x: u64 = 0x2545_F491_4F6C_DD1D;
+        let mut next = || {
+            x ^= x << 13;
+            x ^= x >> 7;
+            x ^= x << 17;
+            x
+        };
+        for i in 1..n {
+            let parent = (next() as usize) % i;
+            let _ = g.add_edge(i.to_string(), parent.to_string());
+        }
+        for _ in 0..extra {
+            let (u, v) = ((next() as usize) % n, (next() as usize) % n);
+            if u != v {
+                let _ = g.add_edge(u.to_string(), v.to_string());
+            }
+        }
+        g
+    }
