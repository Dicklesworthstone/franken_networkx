+/// non-deterministic rayon reduction tree cannot perturb them either.
+fn bitpar_reverse_bfs_run_parallel<const W: usize, S: ReachSink>(
+    offsets: &[u32],
+    targets: &[u32],
+    n: usize,
+    reached: &mut [usize],
+    acc: &mut [S::Acc],
