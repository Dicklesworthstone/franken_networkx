+    /// br-r37-c1-koutdigraphbatch: PROFILE-FIRST A/B for random_uniform_k_out_digraph. Each source
+    /// samples k DISTINCT targets (no dup, no seen-set), never reading the graph. BUT the candidate
+    /// build (O(n)/source → O(n^2)) + the sampling are common to both arms, so the batch may not clear
+    /// the null — profile before optimizing. No production edit until measured. `#[ignore]`; run with
+    /// `cargo test --release -p fnx-generators --lib kout_digraph_batch_ab -- --ignored --nocapture`.
+    #[test]
+    #[ignore = "measurement; run with --release --ignored --nocapture"]
+    fn kout_digraph_batch_ab() {
+        use std::hint::black_box;
+        use std::time::Instant;
+
+        let build_string = |n: usize, k: usize, self_loops: bool, seed: u64| {
+            let (mut g, labels) = super::digraph_with_n_nodes(CompatibilityMode::Strict, n);
+            let mut rng = super::PythonRandom::new(seed);
+            for source in 0..n {
+                let candidates = super::uniform_k_out_candidates(n, source, self_loops);
+                let sample =
+                    super::python_sample_indices(candidates.len(), k, &mut rng, "ab").unwrap();
+                for si in sample {
+                    let _ = g.add_edge(labels[source].clone(), labels[candidates[si]].clone());
+                }
+            }
+            g
+        };
+        let build_batch = |n: usize, k: usize, self_loops: bool, seed: u64| {
+            let (mut g, _labels) = super::digraph_with_n_nodes(CompatibilityMode::Strict, n);
+            let mut rng = super::PythonRandom::new(seed);
+            let mut edges: Vec<(usize, usize, fnx_classes::AttrMap)> = Vec::new();
+            for source in 0..n {
+                let candidates = super::uniform_k_out_candidates(n, source, self_loops);
+                let sample =
+                    super::python_sample_indices(candidates.len(), k, &mut rng, "ab").unwrap();
+                for si in sample {
+                    edges.push((source, candidates[si], fnx_classes::AttrMap::new()));
+                }
+            }
+            let _ = g.extend_existing_index_edges_with_attrs_unrecorded(edges);
+            g
+        };
+
+        for &(n, k, sl, seed) in &[
+            (100usize, 10usize, false, 1u64),
+            (100, 50, true, 7), // self-loops
+            (500, 100, false, 42),
+            (2000, 1000, false, 3),
+        ] {
+            let gs = build_string(n, k, sl, seed);
+            let gb = build_batch(n, k, sl, seed);
+            assert_eq!(
+                gs.edges_ordered_borrowed(),
+                gb.edges_ordered_borrowed(),
+                "directed batch kout({n},{k},{sl},{seed}) must equal per-edge baseline"
+            );
+            assert_eq!(gs.nodes_ordered(), gb.nodes_ordered(), "nodes kout_digraph");
+        }
+
+        // random_uniform_k_out_digraph(2000, 1000): 2000 nodes, 2000000 directed edges.
+        let (n, k, sl, seed) = (2000usize, 1000usize, false, 3u64);
+        let time = |batch: bool| -> f64 {
+            let t0 = Instant::now();
+            if batch {
+                black_box(build_batch(n, k, sl, seed));
+            } else {
+                black_box(build_string(n, k, sl, seed));
+            }
+            t0.elapsed().as_secs_f64()
+        };
+        for _ in 0..3 {
+            black_box(time(true));
+            black_box(time(false));
+        }
+        let median = |v: &[f64]| {
+            let mut s = v.to_vec();
+            s.sort_by(|a, b| a.partial_cmp(b).unwrap());
+            s[s.len() / 2]
+        };
+        let rounds = 61usize;
+        let paired = |cand: bool, base_arm: bool| -> Vec<f64> {
+            let mut v = Vec::with_capacity(rounds);
+            for round in 0..rounds {
+                let (tb, tc) = if round.is_multiple_of(2) {
+                    let bt = time(base_arm);
+                    let ct = time(cand);
+                    (bt, ct)
+                } else {
+                    let ct = time(cand);
+                    let bt = time(base_arm);
+                    (bt, ct)
+                };
+                v.push(tb / tc);
+            }
+            v
+        };
+        let report = |name: &str, ratios: &[f64]| {
+            let wins = ratios.iter().filter(|&&r| r > 1.0).count();
+            let mut sorted = ratios.to_vec();
+            sorted.sort_by(|a, b| a.partial_cmp(b).unwrap());
+            println!(
+                "KOUT_DIGRAPH_BATCH_AB {name}: median={:.4}x win_rate={wins}/{rounds} \
+                 p5_p95=[{:.4},{:.4}]",
+                median(ratios),
+                sorted[rounds * 5 / 100],
+                sorted[rounds * 95 / 100],
+            );
+        };
+        println!("KOUT_DIGRAPH_BATCH_AB n={n} k={k} rounds={rounds} (>1 = batch faster)");
+        report("BATCH_vs_string", &paired(true, false));
+        report("NULL_batch_vs_batch", &paired(true, true));
+    }
+
     fn packet_007_forensics_bundle(
