+            let r = if cand {
+                super::chordal_graph_treewidth(&g).unwrap()
+            } else {
+                old_tw(&g)
+            };
+            black_box(r);
+            t0.elapsed().as_secs_f64()
+        };
+        for _ in 0..3 {
+            black_box(time(true));
+            black_box(time(false));
+        }
