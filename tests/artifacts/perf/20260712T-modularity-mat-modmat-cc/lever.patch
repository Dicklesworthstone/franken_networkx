+    /// br-r37-c1-modmat: paired-interleaved median A/B for modularity's setup — inline ORIGINAL
+    /// (nodes_ordered 3x + the m2 neighbour-sum pass computed separately from k) vs the shipped fold
+    /// (nodes once, k once, m2 = sum(k)), one binary / one worker with a NULL control. A dense circulant
+    /// (1000 nodes, deg 30) partitioned into 250 communities of 4 makes the setup dominate, so removing
+    /// the redundant m2 pass shows. ULP parity asserted first. `#[ignore]`; run with
+    /// `cargo test --release -p fnx-algorithms --lib modularity_mat_ab -- --ignored --nocapture`.
+    #[test]
+    #[ignore = "measurement; run with --release --ignored --nocapture"]
+    fn modularity_mat_ab() {
+        use crate::edge_weight_or_default;
+        use std::collections::HashMap;
+        use std::hint::black_box;
+        use std::time::Instant;
+
+        let weight = "weight";
+        let mut graph = Graph::strict();
+        for i in 0..1000usize {
+            let _ = graph.add_node(i.to_string());
+        }
+        for i in 0..1000usize {
+            for d in 1..=15usize {
+                let j = (i + d) % 1000;
+                if i != j {
+                    let _ = graph.add_edge(i.to_string(), j.to_string());
+                }
+            }
+        }
+        let communities: Vec<Vec<String>> = (0..1000)
+            .step_by(4)
+            .map(|s| (s..s + 4).map(|i| i.to_string()).collect())
+            .collect();
+
+        let build = |batch: bool| -> f64 {
+            if batch {
+                let nodes = graph.nodes_ordered();
+                let k: Vec<f64> = nodes
+                    .iter()
+                    .map(|&nd| {
+                        graph
+                            .neighbors(nd)
+                            .unwrap_or_default()
+                            .iter()
+                            .map(|nbr| edge_weight_or_default(&graph, nd, nbr, weight))
+                            .sum()
+                    })
+                    .collect();
+                let m2: f64 = k.iter().sum();
+                if m2 == 0.0 {
+                    return 0.0;
+                }
+                let node_to_idx: HashMap<&str, usize> =
+                    nodes.iter().enumerate().map(|(i, &nd)| (nd, i)).collect();
+                let mut q = 0.0;
+                for comm in &communities {
+                    for u in comm {
+                        if let Some(&ui) = node_to_idx.get(u.as_str()) {
+                            for v in comm {
+                                if let Some(&vi) = node_to_idx.get(v.as_str()) {
+                                    let a_uv = if graph.has_edge(u, v) {
+                                        edge_weight_or_default(&graph, u, v, weight)
+                                    } else {
+                                        0.0
+                                    };
+                                    q += a_uv - 1.0 * k[ui] * k[vi] / m2;
+                                }
+                            }
+                        }
+                    }
+                }
+                q / m2
+            } else {
+                let m2: f64 = graph
+                    .nodes_ordered()
+                    .iter()
+                    .map(|&nd| {
+                        graph
+                            .neighbors(nd)
+                            .unwrap_or_default()
+                            .iter()
+                            .map(|nbr| edge_weight_or_default(&graph, nd, nbr, weight))
+                            .sum::<f64>()
+                    })
+                    .sum::<f64>();
+                if m2 == 0.0 {
+                    return 0.0;
+                }
+                let node_to_idx: HashMap<&str, usize> = graph
+                    .nodes_ordered()
+                    .iter()
+                    .enumerate()
+                    .map(|(i, &nd)| (nd, i))
+                    .collect();
+                let nodes = graph.nodes_ordered();
+                let k: Vec<f64> = nodes
+                    .iter()
+                    .map(|&nd| {
+                        graph
+                            .neighbors(nd)
+                            .unwrap_or_default()
+                            .iter()
+                            .map(|nbr| edge_weight_or_default(&graph, nd, nbr, weight))
+                            .sum()
+                    })
+                    .collect();
+                let mut q = 0.0;
+                for comm in &communities {
+                    for u in comm {
+                        if let Some(&ui) = node_to_idx.get(u.as_str()) {
+                            for v in comm {
+                                if let Some(&vi) = node_to_idx.get(v.as_str()) {
+                                    let a_uv = if graph.has_edge(u, v) {
+                                        edge_weight_or_default(&graph, u, v, weight)
+                                    } else {
+                                        0.0
+                                    };
+                                    q += a_uv - 1.0 * k[ui] * k[vi] / m2;
+                                }
+                            }
+                        }
+                    }
+                }
+                q / m2
+            }
+        };
+
+        let old = build(false);
+        let new = build(true);
+        assert_eq!(old.to_bits(), new.to_bits(), "modularity fold must be ULP-identical");
+
+        let time = |batch: bool| -> f64 {
+            let t0 = Instant::now();
+            black_box(build(batch));
+            t0.elapsed().as_secs_f64()
+        };
+        for _ in 0..3 {
+            black_box(time(true));
+            black_box(time(false));
+        }
+        let median = |v: &[f64]| {
+            let mut s = v.to_vec();
+            s.sort_by(|a, b| a.partial_cmp(b).unwrap());
+            s[s.len() / 2]
+        };
+        let rounds = 61usize;
+        let paired = |cand: bool, base_arm: bool| -> Vec<f64> {
+            let mut v = Vec::with_capacity(rounds);
+            for round in 0..rounds {
+                let (tb, tc) = if round.is_multiple_of(2) {
+                    let bt = time(base_arm);
+                    let ct = time(cand);
+                    (bt, ct)
+                } else {
+                    let ct = time(cand);
+                    let bt = time(base_arm);
+                    (bt, ct)
+                };
+                v.push(tb / tc);
+            }
+            v
+        };
+        let report = |name: &str, ratios: &[f64]| {
+            let wins = ratios.iter().filter(|&&r| r > 1.0).count();
+            let mut sorted = ratios.to_vec();
+            sorted.sort_by(|a, b| a.partial_cmp(b).unwrap());
+            println!(
+                "MODMAT_AB {name}: median={:.4}x win_rate={wins}/{rounds} \
+                 p5_p95=[{:.4},{:.4}]",
+                median(ratios),
+                sorted[rounds * 5 / 100],
+                sorted[rounds * 95 / 100],
+            );
+        };
+        println!("MODMAT_AB circ1000_comm4 rounds={rounds} (>1 = fold faster)");
+        report("FOLD_vs_orig", &paired(true, false));
+        report("NULL_fold_vs_fold", &paired(true, true));
+    }
+
