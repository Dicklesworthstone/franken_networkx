+    /// br-r37-c1-complementdigraphbatch: paired-interleaved median A/B for complement_digraph — inline
+    /// per-edge baseline vs the shipped batch, one binary / one worker with a NULL control. Sparse
+    /// digraph → dense directed complement. Byte-identity asserted first. `#[ignore]`; run with
+    /// `cargo test --release -p fnx-algorithms --lib complement_digraph_batch_ab -- --ignored --nocapture`.
+    #[test]
+    #[ignore = "measurement; run with --release --ignored --nocapture"]
+    fn complement_digraph_batch_ab() {
+        use std::hint::black_box;
+        use std::time::Instant;
+
+        // Sparse directed input: directed cycle on 400 nodes (400 edges) → complement ~158800 edges.
+        let mut input = DiGraph::strict();
+        let n = 400usize;
+        for i in 0..n {
+            let _ = input.add_node(format!("{i}"));
+        }
+        for i in 0..n {
+            let _ = input.add_edge(format!("{i}"), format!("{}", (i + 1) % n));
+        }
+
+        let build = |g: &DiGraph, batch: bool| -> DiGraph {
+            let nodes = g.nodes_ordered();
+            let mut result = DiGraph::with_runtime_policy(g.runtime_policy().clone());
+            for &node in &nodes {
+                result.add_node(node.to_owned());
+            }
+            if batch {
+                let mut edges: Vec<(String, String)> = Vec::new();
+                for &u in &nodes {
+                    for &v in &nodes {
+                        if u != v && !g.has_edge(u, v) {
+                            edges.push((u.to_owned(), v.to_owned()));
+                        }
+                    }
+                }
+                let _ = result.extend_edges_unrecorded(edges);
+            } else {
+                for &u in &nodes {
+                    for &v in &nodes {
+                        if u != v && !g.has_edge(u, v) {
+                            let _ = result.add_edge(u.to_owned(), v.to_owned());
+                        }
+                    }
+                }
+            }
+            result
+        };
+
+        let old = build(&input, false);
+        let new = build(&input, true);
+        assert_eq!(
+            old.edges_ordered_borrowed(),
+            new.edges_ordered_borrowed(),
+            "batch complement_digraph must equal the per-edge baseline"
+        );
+        assert_eq!(old.nodes_ordered(), new.nodes_ordered());
+
+        let time = |batch: bool| -> f64 {
+            let t0 = Instant::now();
+            black_box(build(&input, batch));
+            t0.elapsed().as_secs_f64()
+        };
+        for _ in 0..3 {
+            black_box(time(true));
+            black_box(time(false));
+        }
+        let median = |v: &[f64]| {
+            let mut s = v.to_vec();
+            s.sort_by(|a, b| a.partial_cmp(b).unwrap());
+            s[s.len() / 2]
+        };
+        let rounds = 61usize;
+        let paired = |cand: bool, base_arm: bool| -> Vec<f64> {
+            let mut v = Vec::with_capacity(rounds);
+            for round in 0..rounds {
+                let (tb, tc) = if round.is_multiple_of(2) {
+                    let bt = time(base_arm);
+                    let ct = time(cand);
+                    (bt, ct)
+                } else {
+                    let ct = time(cand);
+                    let bt = time(base_arm);
+                    (bt, ct)
+                };
+                v.push(tb / tc);
+            }
+            v
+        };
+        let report = |name: &str, ratios: &[f64]| {
+            let wins = ratios.iter().filter(|&&r| r > 1.0).count();
+            let mut sorted = ratios.to_vec();
+            sorted.sort_by(|a, b| a.partial_cmp(b).unwrap());
+            println!(
+                "COMPLEMENT_DIGRAPH_BATCH_AB {name}: median={:.4}x win_rate={wins}/{rounds} \
+                 p5_p95=[{:.4},{:.4}]",
+                median(ratios),
+                sorted[rounds * 5 / 100],
+                sorted[rounds * 95 / 100],
+            );
+        };
+        println!("COMPLEMENT_DIGRAPH_BATCH_AB dcycle400 rounds={rounds} (>1 = batch faster)");
+        report("BATCH_vs_string", &paired(true, false));
+        report("NULL_batch_vs_batch", &paired(true, true));
+    }
+
